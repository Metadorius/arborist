{% extends "base.html.j2" %}
{% block title %}{{ thread.name }} — Arborist{% endblock %}

{% block content %}
<p class="breadcrumb"><a href="{{ root }}index.html">Home</a> / <a href="{{ root }}channels/{{ channel.id }}/index.html"># {{ channel.name }}</a> / <span class="muted">{{ thread.name }}</span></p>
<h1>{{ thread.name }}</h1>
<p class="muted">{{ channel.name }} — {{ messages|length }} message{% if messages|length != 1 %}s{% endif %}</p>
<hr>
{% for msg in messages %}
  {% include "message.html.j2" %}
{% endfor %}
{% endblock %}
