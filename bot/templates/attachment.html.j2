{% set att_url = root ~ "attachments/" ~ att.channel_id ~ "/" ~ att.id ~ "/" ~ att.filename %}
{% if att.is_image %}
  <a href="{{ att_url }}" target="_blank"><img src="{{ att_url }}" alt="{{ att.filename }}" loading="lazy"></a>
  <span class="attachment-meta">{{ att.filename }} — {{ att.size | filesize }}</span>
{% else %}
  <a href="{{ att_url }}" class="attachment-link">
    <span class="attachment-link-icon">📎</span>
    <span class="attachment-link-text">
      <span class="attachment-link-name">{{ att.filename }}</span>
      <span class="attachment-link-size">{{ att.size | filesize }}</span>
    </span>
  </a>
{% endif %}
