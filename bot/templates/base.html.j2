<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}Arborist{% endblock %}</title>
<link rel="stylesheet" href="{{ root }}styles.css">
</head>
<body>
<div id="topbar">
  <button id="sidebar-toggle" type="button"
          aria-controls="sidebar" aria-expanded="false" aria-label="Toggle menu">
    <span class="sidebar-toggle-icon" aria-hidden="true"></span>
  </button>
  <span class="topbar-title">🌳 Arborist</span>
  <span class="topbar-spacer"></span>
</div>
<div id="sidebar">
  <nav id="channel-list">
    {% for ch in tree %}
      <details class="tree-channel">
        <summary>
          <a class="tree-channel-link"
             href="{{ root }}channels/{{ ch.folder }}/index.html"
             data-path="channels/{{ ch.id }}"
             onclick="event.stopPropagation()"># {{ ch.name }}</a>
        </summary>
        {% if ch.threads %}
          {% for th in ch.threads %}
            <a class="tree-thread"
               href="{{ root }}channels/{{ th.folder }}/index.html"
               data-path="channels/{{ th.folder }}">{{ th.name }}</a>
          {% endfor %}
        {% endif %}
      </details>
    {% endfor %}
  </nav>
</div>
<main id="content">
  {% block content %}{% endblock %}
</main>
<script>
(function(){
  var path = location.pathname.replace(/\/index\.html$/, '').replace(/\/$/, '');
  var links = document.querySelectorAll('#channel-list a[data-path]');
  var best = null, bestLen = 0;
  for (var i = 0; i < links.length; i++) {
    var dp = links[i].getAttribute('data-path');
    if (!dp) continue;
    var matched = (path === dp) ||
                  path.endsWith('/' + dp) ||
                  path.indexOf('/' + dp + '/') !== -1;
    if (matched && dp.length > bestLen) {
      best = links[i]; bestLen = dp.length;
    }
  }
  if (best) best.classList.add('active');
  var p = best ? best.closest('details') : null;
  if (p) p.open = true;

  var btn = document.getElementById('sidebar-toggle');
  var sidebar = document.getElementById('sidebar');
  btn.addEventListener('click', function(e){
    e.stopPropagation();
    var open = sidebar.classList.toggle('open');
    btn.setAttribute('aria-expanded', open ? 'true' : 'false');
  });
  document.addEventListener('click', function(e) {
    if (sidebar.classList.contains('open') &&
        !sidebar.contains(e.target) &&
        e.target !== btn && !btn.contains(e.target)) {
      sidebar.classList.remove('open');
      btn.setAttribute('aria-expanded', 'false');
    }
  });
})();
</script>
</body>
</html>
