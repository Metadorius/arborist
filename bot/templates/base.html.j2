<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}Arborist{% endblock %}</title>
<link rel="stylesheet" href="{{ root }}styles.css">
</head>
<body>
<div id="sidebar">
  <div id="sidebar-header">
    <h1><a href="{{ root }}index.html">🌳 Arborist</a></h1>
  </div>
  <nav id="channel-list">
    {% for ch in tree %}
      <details class="tree-channel">
        <summary>
          <a class="tree-channel-link"
             href="{{ root }}channels/{{ ch.folder }}/index.html"
             data-path="channels/{{ ch.id }}"
             onclick="event.stopPropagation()"># {{ ch.name }}</a>
        </summary>
        {% if ch.threads %}
          {% for th in ch.threads %}
            <a class="tree-thread"
               href="{{ root }}channels/{{ th.folder }}/index.html"
               data-path="channels/{{ th.folder }}">{{ th.name }}</a>
          {% endfor %}
        {% endif %}
      </details>
    {% endfor %}
  </nav>
</div>
<main id="content">
  {% block content %}{% endblock %}
</main>
<script>
(function(){
  var path = location.pathname.replace(/\/$/, '');
  var links = document.querySelectorAll('#channel-list a[data-path]');
  var best = null, bestLen = 0;
  for (var i = 0; i < links.length; i++) {
    var dp = links[i].getAttribute('data-path');
    if (dp && path.indexOf(dp) !== -1 && dp.length > bestLen) {
      best = links[i]; bestLen = dp.length;
    }
  }
  if (best) best.classList.add('active');
  var p = best ? best.closest('details') : null;
  if (p) p.open = true;
  document.getElementById('sidebar-header').addEventListener('click', function(){
    document.getElementById('sidebar').classList.toggle('open');
  });
})();
</script>
</body>
</html>
